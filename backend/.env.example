# AgentArena — Environment Variables
# Copy to .env in /backend and fill in your values

# ─── Required for Gemini Live Features ───────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Server ──────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=true
COMMENTARY_STYLE=hype

# ─── Phase 2 (Optional) ──────────────────────────────────────────────────────
# POLYGON_RPC_URL=
# AGENT_NFT_CONTRACT=
# FIREBASE_PROJECT_ID=
# REDIS_URL=redis://localhost:6379
