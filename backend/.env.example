# AgentArena Backend — Environment Variables
# Copy this file to .env and fill in real values.

# ─── Google AI (required) ────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL_FLASH=gemini-2.0-flash
GEMINI_MODEL_PRO=gemini-2.0-pro

# ─── Server ──────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=false
COMMENTARY_STYLE=hype

# ─── Security ────────────────────────────────────────────────────────
JWT_SECRET=replace-with-a-strong-random-secret
# Comma-separated CORS origins (use * for dev only)
ALLOWED_ORIGINS=https://agentarena.io

# ─── Frontend URL ────────────────────────────────────────────────────
FRONTEND_URL=https://agentarena.io

# ─── Blockchain — Polygon ────────────────────────────────────────────
POLYGON_RPC_URL=https://polygon-rpc.com
POLYGON_AMOY_RPC=https://rpc-amoy.polygon.technology
# Fill after: npx hardhat run scripts/deploy.js --network polygon
ARENA_TOKEN_CONTRACT=
AGENT_NFT_CONTRACT=
SKILL_NFT_CONTRACT=
ZK_BETTING_POOL_CONTRACT=
RESULT_ORACLE_CONTRACT=

# ─── Redis ───────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Firebase (optional) ─────────────────────────────────────────────
FIREBASE_PROJECT_ID=

# ─── Cloud Storage (optional) ────────────────────────────────────────
GCS_BUCKET=
